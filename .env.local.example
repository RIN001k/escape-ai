GEMINI_API_KEY=your_gemini_api_key_here

# RapidAPI key for booking-com15.p.rapidapi.com (real hotel data)
# Optional: if absent, the app falls back to AI-generated hotel data.
RAPIDAPI_KEY=your_rapidapi_key_here

# Unsplash API key for beautiful city photos (https://unsplash.com/developers)
# Optional: if absent, falls back to Wikimedia Commons photos.
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
